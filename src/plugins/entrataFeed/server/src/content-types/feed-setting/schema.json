{
  "kind": "singleType",
  "collectionName": "feed_settings",
  "info": {
    "singularName": "feed-setting",
    "pluralName": "feed-settings",
    "displayName": "Feed Settings"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "enableEngrainPricing": {
      "type": "boolean",
      "default": false
    },
    "engrainApiUrl": {
      "type": "string",
      "default": "https://api.sightmap.com/v1/assets/21672/multifamily/expenses",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "enableEngrainPricing"
            },
            true
          ]
        }
      }
    },
    "engrainPrice": {
      "type": "string",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "enableEngrainPricing"
            },
            true
          ]
        }
      }
    },
    "priceIncrement": {
      "type": "integer",
      "default": 1000
    },
    "sqftIncrement": {
      "type": "integer",
      "default": 500
    }
  }
}
