{
  "kind": "singleType",
  "collectionName": "engrain-pricing",
  "info": {
    "singularName": "engrain-pricing",
    "pluralName": "engrain-pricing",
    "displayName": "Engrain Pricing",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "enableEngrainPricing": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "engrainApiUrl": {
      "type": "string",
      "default": "https://api.sightmap.com/v1/assets/21672/multifamily/expenses"
    },
    "engrainPrice": {
      "type": "string",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "enableEngrainPricing"
            },
            true
          ]
        }
      }
    },
    "engrainFeeCalculatorTitle": {
      "type": "string",
      "default": "Budget With Ease"
    },
    "description": {
      "type": "text"
    },
    "shortDisclaimer": {
      "type": "string"
    },
    "longDisclaimer": {
      "type": "text"
    }
  }
}
