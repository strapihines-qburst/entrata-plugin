{
    "kind": "collectionType",
    "collectionName": "specials",
    "info": {
      "singularName": "special",
      "pluralName": "specials",
      "displayName": "special",
      "description": ""
    },
    "options": {
      "draftAndPublish": true
    },
    "pluginOptions": {
    "content-manager": {
      "visible": true
    }
  },
    "attributes": {
      "special_id": {
        "type":"string"
      },
      "special_type": {
      "type":"enumeration",
        "enum":["floorplan","unit","floorplanType"],
        "required":true
      },
      "floorplans": {
        "type":"relation",
        "relation":"oneToMany",
        "target":"plugin::entratafeed.floorplan"
      },
      "units": {
        "type":"relation",
        "relation":"oneToMany",
        "target":"plugin::entratafeed.unit"
      },
      "floorplanTypes": {
        "type": "json"
      },
      "specials": {
        "type": "component",
        "repeatable": false,
        "component": "plugin::entratafeed.special-details"
      }
    }
  }